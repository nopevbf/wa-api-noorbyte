# Ignore node_modules and environment files
node_modules/
**/node_modules/**
*/node_modules/**
.env
.env.*
!.env.example

# Ignore session data files (keep the folder structure)
sessions/
backend/sessions/**
!backend/sessions/.gitkeep

# Ignore Puppeteer browser sessions
**/browser_session*/

# Ignore database files
**/database.db
backend/database.db
**/database.sqlite
**/db/*
*.db
*.sqlite

# Ignore API keys and tokens
**/api_keys.json
**/api_tokens.json
**/credentials.json
**/creds.json

# Ignore log files
**/logs/*.log
*.log

# Ignore temporary files
**/temp/*.tmp
*.tmp

# Ignore backup files
**/backup/*.bak
*.bak

# Ignore compiled files
**/dist/
**/build/

# Ignore IDE files
**/.idea/
**/.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Ignore deployment files
**/deploy/
**/deployments/

# Ignore generated files
**/generated/
**/generated_files/

# Ignore cache files
**/cache/
**/cache_files/

# Ignore Python bytecode files
__pycache__/
**/__pycache__/
*.pyc
*.pyo

# Ignore test files
**/tests/
backend/tests/
**/test/
