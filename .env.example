# ============================================
# Environment Configuration (TEMPLATE)
# ============================================
# Copy file ini jadi .env lalu sesuaikan value-nya
# Ubah NODE_ENV ke "production" untuk pakai API prod
# Opsi: "development" | "production"
NODE_ENV=development

# DParagon API Base URLs
DPARAGON_API_URL_DEV=https://api.dparagon6.persona-it.com/v2
DPARAGON_API_URL_PROD=https://api.dparagon.com/v2
